{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdTool",
  "version": "0.1.3",
  "identifier": "com.mdtool.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "bash before-build.sh || bash ../before-build.sh"
  },
  "app": {
    "windows": [
      {
        "title": "mdTool",
        "width": 1100,
        "height": 800,
        "minWidth": 600,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../bundle-staging/mdTool": "mdTool"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}