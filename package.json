{
  "name": "mdtool",
  "version": "0.1.0",
  "description": "Render Markdown and Jupyter notebooks with beautiful themes and export faithful PDFs.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mdtool": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "pdf": "node --import tsx src/cli.ts",
    "playwright:install": "playwright install chromium",
    "dev": "npm --prefix tauri-app run build && node $PWD/tauri-app/dev-server.mjs",
    "bundle-core": "bash bundle-core.sh",
    "tauri": "tauri",
    "make-dmg": "bash make-dmg.sh"
  },
  "keywords": [
    "markdown",
    "jupyter",
    "notebook",
    "pdf",
    "theme",
    "render"
  ],
  "license": "MIT",
  "dependencies": {
    "katex": "^0.16.11",
    "mermaid": "^11.4.0",
    "playwright": "^1.48.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "shiki": "^1.22.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@tauri-apps/cli": "^2.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
